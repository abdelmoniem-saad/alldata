FROM python:3.12-slim

# Install data science packages for the sandbox
RUN pip install --no-cache-dir \
    numpy \
    pandas \
    scipy \
    matplotlib \
    seaborn \
    statsmodels \
    scikit-learn \
    sympy

# Create a non-root user for execution
RUN useradd -m -s /bin/bash sandbox
USER sandbox
WORKDIR /home/sandbox

# No CMD — containers are spawned with specific commands
